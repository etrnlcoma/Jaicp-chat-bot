require: slotfilling/slotFilling.sc
  module = sys.zb-common
theme: /

    state: hello
        q!: * [привет|здравствуй|здравствуйте|добрый день|добрый вечер|доброе утро|хай|hello|hi|hey|start] *
        q!: /start
        q!: начать
        q!: начало
        q!: запустить
        q!: помощь
        q!: help
        a: Привет! Я бот-помощник. 🌤 Я могу рассказать о погоде или курсах валют.
        a: Попробуй спросить:
        a: — «Какая погода?»
        a: — «Какой курс доллара?»

    state: weather
        q!: * [погода|прогноз|температура|дождь|снег|гроза|солнце|облачно|ветер|климат|осадки|weather|forecast|temperature|rain|snow|sun|cloud|wind] *
        q!: какая погода
        q!: расскажи о погоде
        q!: что с погодой
        q!: прогноз погоды
        q!: погодные условия
        q!: будет ли дождь
        q!: тепло ли сегодня
        q!: холодно ли на улице
        q!: нужна ли куртка
        a: 🌤 Прогноз погоды на сегодня:
        a: Температура: +20°C (ощущается как +18°C)
        a: Небо: переменная облачность
        a: Ветер: 5 м/с, юго-западный
        a: Осадков не ожидается. Хорошего дня!

    state: currency
        q!: * [курс|валюта|доллар|евро|рубль|юань|фунт|currency|dollar|euro|ruble|forex|exchange|usd|eur|rub|cny|gbp] *
        q!: курс валют
        q!: сколько стоит доллар
        q!: сколько стоит евро
        q!: курс доллара сегодня
        q!: курс евро сегодня
        q!: валютный курс
        q!: обменный курс
        q!: что с валютой
        q!: расскажи о валюте
        a: 💱 Актуальные курсы валют:
        a: 🇺🇸 1 USD = 82.50 ₽
        a: 🇪🇺 1 EUR = 89.30 ₽
        a: 🇬🇧 1 GBP = 104.20 ₽
        a: 🇨🇳 1 CNY = 11.35 ₽

    state: NoMatch
        event!: noMatch
        a: Извините, я не понял ваш запрос. 🤔
        a: Я умею рассказывать о погоде и курсах валют.
        a: Попробуйте спросить: «Какая погода?» или «Какой курс доллара?»
